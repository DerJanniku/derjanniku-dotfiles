{
    "layer": "top",
    "position": "top",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 40,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "mpris",
        "network",
        "cpu",
        "memory",
        "pulseaudio",
        "battery",
        "tray"
    ],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "1": "≤░▓ι",
            "2": "≤░▓λ",
            "3": "≤░▓ν",
            "4": "≤░▓ο",
            "5": "≤░▓ρ",
            "urgent": "ΎΒς",
            "active": "ΎΗΤ",
            "default": "ΎΕΣ"
        }
    },
    "hyprland/window": {
        "format": " {title} ",
        "max-length": 50,
        "separate-outputs": true
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "mpris": {
        "format": "{player_icon}  {dynamic}",
        "format-paused": "{status_icon} {player_icon}  <i>{dynamic}</i>",
        "player-icons": {
            "default": "ΎΑΒ",
            "firefox": "ΎΚσ",
            "plasma-browser-integration": "ΎΚσ",
            "apple-music": "ΎΑΒ"
        },
        "status-icons": {
            "paused": "≤░Πν"
        },
        "dynamic-order": [
            "title",
            "artist"
        ],
        "max-length": 40
    },
    "clock": {
        "format": "ΎΑΩ  {:%H:%M  ≤░Δφ  %d.%m.%Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },
    "cpu": {
        "interval": 10,
        "format": "ΎΜδ  {usage}%",
        "max-length": 10
    },
    "memory": {
        "interval": 30,
        "format": "ΎΔΚ  {used:0.1f}G",
        "format-alt": "ΎΔΚ  {percentage}%",
        "max-length": 10
    },
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "Ύγσ ",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΨΡ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": [
                "ΎΑο",
                "ΎΑπ",
                "ΎΑρ"
            ]
        },
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "ΎΘτ   {signalStrength}%",
        "format-ethernet": "≤░ΙΑ   Connected",
        "format-disconnected": "έγι  Disconnected",
        "tooltip-format": "{ifname} via {gwaddr} ΎηΨ",
        "format-alt": "≤░ΙΑ  {ipaddr}/{cidr}"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "ΎΩπ  {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "ΎΚΕ",
            "ΎΚΔ",
            "ΎΚΓ",
            "ΎΚΒ",
            "ΎΚΑ"
        ]
    }
}