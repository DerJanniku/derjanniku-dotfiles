# --- Mako Custom Template ---
# Matches Nexus Capsule Style

font=JetBrainsMono Nerd Font 11
width=350
height=150
margin=20
padding=15
border-size=3
border-radius=12
icons=1
max-icon-size=48
default-timeout=8000
ignore-timeout=0

# Colors (will be replaced by theme switcher)
background-color=#1a1b26d8
text-color=#c0caf5
border-color=#7aa2f7
progress-color=over #7aa2f7

[urgency=low]
border-color=#7aa2f7

[urgency=normal]
border-color=#7aa2f7

[urgency=critical]
border-color=#ff5555
default-timeout=0
